# =============================================================================
# Snowflake
# =============================================================================
SNOWFLAKE_ACCOUNT=your_account.us-east-1       # e.g., abc12345.us-east-1
SNOWFLAKE_USER=SCHEDULING_API_USER
SNOWFLAKE_WAREHOUSE=SCHEDULING_APP_WH
SNOWFLAKE_DATABASE=COOKIECUTTERSCORP
SNOWFLAKE_SCHEMA=SCHEDULING_APP
SNOWFLAKE_ROLE=SCHEDULING_SERVICE_ROLE

# Auth method: "password" or "keypair"
SNOWFLAKE_AUTH_METHOD=keypair

# If using password auth:
# SNOWFLAKE_PASSWORD=your_password_here

# If using key-pair auth (pick ONE of these two):
SNOWFLAKE_PRIVATE_KEY_PATH=/path/to/rsa_key.p8             # For local dev / VMs
# SNOWFLAKE_PRIVATE_KEY_BASE64=MIIEvgIBADANBgkqhki...      # For serverless (Vercel, Lambda)
SNOWFLAKE_PRIVATE_KEY_PASSPHRASE=                           # Leave blank if key is unencrypted

# Connection pool settings
SNOWFLAKE_POOL_SIZE=5                          # Max concurrent connections
SNOWFLAKE_POOL_TIMEOUT=30                      # Seconds to wait for a connection

# =============================================================================
# Supabase Auth
# =============================================================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_JWT_SECRET=your_jwt_secret_here       # Found in Supabase > Settings > API > JWT Secret

# =============================================================================
# App
# =============================================================================
APP_ENV=development                            # development | staging | production
APP_DEBUG=true
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,https://your-app.vercel.app
